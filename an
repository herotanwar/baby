package com.example.practical3

import android.content.Intent
import android.os.Bundle
import android.widget.ArrayAdapter
import android.widget.ListView
import androidx.appcompat.app.AppCompatActivity

class MainActivity : AppCompatActivity() {

    private val layouts = arrayOf(
        "LinearLayout", "RelativeLayout", "TableLayout",
        "AbsoluteLayout", "FrameLayout", "ListView", "GridView", "CoordinatorLayout"
    )

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val listView = findViewById<ListView>(R.id.layoutListView)
        val adapter = ArrayAdapter(this, android.R.layout.simple_list_item_1, layouts)
        listView.adapter = adapter

        listView.setOnItemClickListener { _, _, position, _ ->
            val selectedLayout = layouts[position]
            val intent = Intent(this, LayoutActivity::class.java)
            intent.putExtra("layoutName", selectedLayout)
            startActivity(intent)
        }
    }
}

LayoutActivity:-
package com.example.practical3

import android.os.Bundle
import android.widget.ArrayAdapter
import android.widget.GridView
import android.widget.ListView
import androidx.appcompat.app.AppCompatActivity

class LayoutActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        val layoutName = intent.getStringExtra("layoutName")

        when (layoutName) {
            "LinearLayout" -> setContentView(R.layout.layout_linear)
            "RelativeLayout" -> setContentView(R.layout.layout_relative)
            "TableLayout" -> setContentView(R.layout.layout_table)
            "AbsoluteLayout" -> setContentView(R.layout.layout_absolute)
            "FrameLayout" -> setContentView(R.layout.layout_frame)
            "ListView" -> {
                setContentView(R.layout.layout_listview)
                val listView = findViewById<ListView>(R.id.sampleListView)
                val data = arrayOf("My", "Name", "is", "Alexa","Ok")
                listView.adapter = ArrayAdapter(this, android.R.layout.simple_list_item_1, data)
            }
            "GridView" -> {
                setContentView(R.layout.layout_gridview)
                val gridView = findViewById<GridView>(R.id.sampleGridView)
                val data = arrayOf("A", "B", "C", "D", "E", "F", "G", "H", "I")
                gridView.adapter = ArrayAdapter(this, android.R.layout.simple_list_item_1, data)
            }
            "CoordinatorLayout" -> setContentView(R.layout.layout_coordinator)
        }
    }
}

