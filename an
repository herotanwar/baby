package com.example.practicals15

import android.annotation.SuppressLint
import android.os.Bundle
import android.view.KeyEvent
import android.view.MotionEvent
import android.view.View
import android.widget.Button
import android.widget.EditText
import android.widget.TextView
import androidx.activity.enableEdgeToEdge
import androidx.appcompat.app.AppCompatActivity
import androidx.core.view.ViewCompat
import androidx.core.view.WindowInsetsCompat

class MainActivity : AppCompatActivity() {

    @SuppressLint("ClickableViewAccessibility", "SetTextI18n")
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContentView(R.layout.activity_main)

        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main)) { v, insets ->
            val systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars())
            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom)
            insets
        }

        val messageTextView = findViewById<TextView>(R.id.messageTextView)
        val testEditText = findViewById<EditText>(R.id.testEditText)
        val testButton = findViewById<Button>(R.id.testButton)
        val touchArea = findViewById<View>(R.id.touchArea)

        // 1. Button Click Event
        testButton.setOnClickListener {
            messageTextView.text = "Event: Button Clicked"
        }

        // 2. Button Long Click Event
        testButton.setOnLongClickListener {
            messageTextView.text = "Event: Button Long Clicked"
            true
        }

        // 3. EditText Key Event (detecting Enter key)
        testEditText.setOnKeyListener { v, keyCode, event ->
            if (event.action == KeyEvent.ACTION_DOWN && keyCode == KeyEvent.KEYCODE_ENTER) {
                val input = (v as EditText).text.toString()
                messageTextView.text = "Event: Enter pressed. Input: $input"
                true
            } else {
                false
            }
        }

        // 4. Touch Event (handling multi-touch)
        touchArea.setOnTouchListener { _, event ->
            val action = event.actionMasked
            when (action) {
                MotionEvent.ACTION_DOWN, MotionEvent.ACTION_POINTER_DOWN -> {
                    messageTextView.text = "Event: Touch Down"
                }
                MotionEvent.ACTION_MOVE -> {
                    val count = event.pointerCount
                    messageTextView.text = "Event: Touch Move ($count pointers active)"
                }
                MotionEvent.ACTION_UP, MotionEvent.ACTION_POINTER_UP -> {
                    messageTextView.text = "Event: Touch Up"
                }
            }
            true
        }
    }
}

